# Get a free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for all text-generation calls (extraction, questions, summary)
GROQ_MODEL=llama-3.3-70b-versatile

# Where Chroma persists its vector data on disk
CHROMA_DB_DIR=./chroma_db

# Where the SQLite file lives
DATABASE_URL=sqlite:///./interview_system.db

# Folder containing role-specific source books, organized as data/books/<role>/*.pdf|*.txt
BOOKS_DIR=./data/books

# How many interview questions to ask before ending a session
MAX_QUESTIONS=5

# How many chunks to retrieve per query
TOP_K=3
